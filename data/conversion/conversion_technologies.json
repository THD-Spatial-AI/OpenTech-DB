{
  "metadata": {
    "domain": "conversion",
    "version": "1.0.0",
    "date_created": "2026-03-04",
    "description": "Comprehensive sector-coupling and conversion technology database aligned with the Open Energy Ontology (OEO). Designed for PyPSA, Calliope, OSeMOSYS, and ADOPTNet0 energy system modeling. Efficiency definitions vary by technology type (see per-technology description).",
    "ontology_base_uri": "http://openenergy-platform.org/ontology/oeo/",
    "notes": {
      "electrolyzers": "efficiency_percent = electrical-to-hydrogen efficiency on LHV basis",
      "fuel_cells": "efficiency_percent = net AC electrical efficiency, LHV basis",
      "heat_pumps": "efficiency_percent = COP expressed as percentage (e.g., COP 3.5 → 350%). capex_usd_per_kw refers to thermal output kW.",
      "electric_boilers": "efficiency_percent = thermal efficiency",
      "chp": "efficiency_percent = total efficiency (electrical + thermal). opex_var_usd_per_mwh based on fuel input.",
      "chemical_processes": "efficiency_percent = energy conversion efficiency to product, LHV basis",
      "dac_ccs": "efficiency_percent = CO2 capture rate. capex_usd_per_kw = USD per kW of compressor/capture power; preferred metric is USD/tCO2 in description."
    },
    "primary_sources": [
      "IRENA Green Hydrogen Cost Reduction 2020",
      "IEA Global Hydrogen Review 2023",
      "NREL Hydrogen Production Cost Analysis 2023",
      "IRENA Innovation Outlook – Electrolysers 2020",
      "BloombergNEF Hydrogen Economy Outlook 2023",
      "European Commission Hydrogen Strategy 2020",
      "IEAGHG CCS Cost Studies 2021",
      "IEA Heat Pumps Tracking Report 2023",
      "NREL Fuel Cell Technology Basics 2022"
    ]
  },
