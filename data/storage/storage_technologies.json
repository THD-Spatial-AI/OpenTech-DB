{
  "metadata": {
    "domain": "storage",
    "version": "1.0.0",
    "date_created": "2026-03-04",
    "description": "Comprehensive storage technology database aligned with the Open Energy Ontology (OEO). Efficiency values represent round-trip efficiency (RTE) for electrical storage, or charge/discharge efficiency for thermal/chemical storage. Designed for PyPSA, Calliope, OSeMOSYS, and ADOPTNet0.",
    "ontology_base_uri": "http://openenergy-platform.org/ontology/oeo/",
    "notes": "For storage: typical_capacity_mw = rated power output; efficiency_percent = round-trip efficiency (electrical) or thermal/chemical storage efficiency; ramping_rate_percent_per_min = discharge ramp rate.",
    "primary_sources": [
      "NREL Grid Energy Storage Technology Cost and Performance Assessment 2022",
      "BloombergNEF Energy Storage Market Outlook 2023",
      "IRENA Electricity Storage and Renewables 2020",
      "Lazard LCOE and LCOS Analysis v8.0 (2023)",
      "PNNL 2022 Grid Energy Storage Cost and Performance Review",
      "IEA Energy Storage Tracking 2023"
    ]
  },
