# ────────────────────────────────────────────────────────────────────────────────
# opentech-db — Frontend environment variables template
#
# Copy this file to frontend/.env.local and fill in your values.
# NEVER commit .env.local to source control.
# ────────────────────────────────────────────────────────────────────────────────

# ── FastAPI backend ───────────────────────────────────────────────────────────
# Defaults to http://localhost:8000/api/v1 when unset.
# Override with a tunnel URL (e.g. ngrok) during remote development.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
# Used for:  email/password auth  |  GitHub OAuth (configured in Supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# ── ORCID OAuth (backend-handled) ─────────────────────────────────────────────
# ORCID is NOT a Supabase provider. The FastAPI backend handles the ORCID OAuth
# dance and redirects back to the SPA with ?token=<jwt>.
# No frontend secret required — all vars below go in the BACKEND .env / Docker.
#
# 1. Register a Public API app at: https://orcid.org/developer-tools
#    Redirect URI must be: http://localhost:8000/api/v1/auth/orcid/callback
#
# 2. Set these in the backend environment:
#    ORCID_ENV=sandbox            # "sandbox" (default, allows http://localhost) or "production"
#    ORCID_CLIENT_ID=APP-XXXXXXXXXXXX
#    ORCID_CLIENT_SECRET=<your-client-secret>
#    ORCID_REDIRECT_URI=http://localhost:8000/api/v1/auth/orcid/callback
#    FRONTEND_URL=http://localhost:5173
#    JWT_SECRET_KEY=<random-32-byte-string>   # python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# GitHub OAuth is handled entirely by Supabase — configure it in:
#   Supabase Dashboard → Auth → Providers → GitHub
#   GitHub OAuth App callback URL: https://<project-ref>.supabase.co/auth/v1/callback
#   Supabase Dashboard → Auth → URL Configuration → Site URL: http://localhost:5173
